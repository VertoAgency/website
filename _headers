# Security + caching headers for Cloudflare Pages

# All pages: security headers
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' calendar.google.com; style-src 'self' 'unsafe-inline' calendar.google.com fonts.googleapis.com; font-src 'self' fonts.gstatic.com; img-src 'self' data:; connect-src 'self' calendar.google.com; frame-src calendar.google.com; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests

# Immutable versioned assets — 1 year cache
/output.css
  Cache-Control: public, max-age=31536000, immutable

# JS files — 1 day TTL (no content hashing; Cloudflare edge purges on deploy)
/js/*.js
  Cache-Control: public, max-age=86400

/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

# Images — 30 days cache
/images/*
  Cache-Control: public, max-age=2592000

# Fonts — 1 year cache (filenames are content-stable)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
