# Security + caching headers for Cloudflare Pages

# All pages: security headers
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' calendar.google.com 'unsafe-inline'; style-src 'self' fonts.googleapis.com 'unsafe-inline'; font-src 'self' fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-src calendar.google.com; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests

# Immutable versioned assets — 1 year cache
/output.css
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

# Images — 30 days cache
/images/*
  Cache-Control: public, max-age=2592000

